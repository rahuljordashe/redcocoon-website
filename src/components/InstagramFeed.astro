---
import { getInstagramDMLink, getInstagramProfileLink } from '../utils/instagram';

const posts = [
  { src: '10.jpg', label: 'Glazing close-up', type: 'photo' },
  { src: 'abyee.jpg', label: 'Throwing a bowl', type: 'reel' },
  { src: 'Tea-coffee-set5.jpg', label: 'Kiln unloading', type: 'photo' },
  { src: 'Kitchen-ware1.jpg', label: 'New mugs lined up', type: 'photo' },
  { src: 'Wall-deco5.jpg', label: 'Glaze mixing', type: 'reel' },
  { src: 'Enamel.jpg', label: 'Studio morning light', type: 'photo' },
];
---

<section class="instagram" id="instagram">
  <div class="container">
    <div class="instagram-header">
      <h2 class="instagram-title">From the Studio</h2>
      <a href={getInstagramProfileLink()} target="_blank" rel="noopener noreferrer" class="instagram-badge">
        @redcocoon
      </a>
    </div>
    <div class="instagram-grid">
      {posts.map(post => (
        <div class="insta-item">
          <img src={`/images/${post.src}`} alt={post.label} loading="lazy" decoding="async" width="300" height="300" class="insta-img" />
          {post.type === 'reel' && <span class="insta-reel-badge">REEL</span>}
        </div>
      ))}
    </div>
    <div class="instagram-cta">
      <a href={getInstagramDMLink()} target="_blank" rel="noopener noreferrer" class="btn btn-instagram">DM Us to Order</a>
      <a href={getInstagramProfileLink()} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">Follow @redcocoon &rarr;</a>
    </div>
  </div>
</section>

<style>
  .instagram {
    padding: var(--space-5xl) 0;
    background: var(--color-white);
  }

  .instagram-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3xl);
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .instagram-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-espresso);
  }

  .instagram-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: white;
    background: var(--gradient-instagram);
    padding: 0.5rem 1rem;
    border-radius: 100px;
    transition: transform var(--transition-fast);
  }

  .instagram-badge:hover {
    transform: scale(1.05);
  }

  .instagram-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-md);
  }

  .insta-item {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: var(--border-radius);
    cursor: pointer;
  }

  .insta-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-med);
  }

  .insta-item:hover .insta-img {
    transform: scale(1.05);
  }

  .insta-reel-badge {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    background: rgba(0, 0, 0, 0.7);
    color: white;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .instagram-cta {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-top: var(--space-3xl);
  }

  @media (max-width: 768px) {
    .instagram-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 480px) {
    .instagram-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
