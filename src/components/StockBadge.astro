---
interface Props {
  stock: number;
  madeToOrder: boolean;
}

const { stock, madeToOrder } = Astro.props;

const status = stock > 0 ? 'available' : madeToOrder ? 'mto' : 'sold';
const label = status === 'available' ? 'Available' : status === 'mto' ? 'Made to Order' : 'Sold';
---

<span class={`stock-badge badge-${status}`}>{label}</span>

<style>
  .stock-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    line-height: 1.4;
  }

  .badge-available {
    background: var(--color-sage);
    color: #fff;
  }

  .badge-sold {
    background: #9e9e9e;
    color: #fff;
  }

  .badge-mto {
    background: var(--color-terracotta);
    color: #fff;
  }
</style>
