---
interface Props {
  tag?: string;
  title: string;
  titleAccent?: string;
  subtitle?: string;
  center?: boolean;
}

const { tag, title, titleAccent, subtitle, center = false } = Astro.props;
---

<div class:list={['section-header', { 'section-header-center': center }]}>
  {tag && <span class="section-tag">{tag}</span>}
  <h2 class="section-title">{title}{titleAccent && <> <em>{titleAccent}</em></>}</h2>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
</div>

<style>
  .section-header {
    margin-bottom: var(--space-3xl);
  }

  .section-tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-extra);
    color: var(--color-terracotta);
    margin-bottom: var(--space-md);
    position: relative;
    padding-left: 2rem;
  }

  .section-tag::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1.25rem;
    height: 1px;
    background: var(--color-terracotta);
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-espresso);
    margin-bottom: var(--space-lg);
  }

  .section-title em {
    font-family: var(--font-elegant);
    font-style: italic;
    font-weight: 400;
    color: var(--color-terracotta);
  }

  .section-subtitle {
    font-size: 1.05rem;
    color: var(--color-clay);
    max-width: 500px;
    line-height: 1.7;
  }

  .section-header-center {
    text-align: center;
  }

  .section-header-center .section-subtitle {
    margin: 0 auto;
  }

  .section-header-center .section-tag {
    padding-left: 0;
  }

  .section-header-center .section-tag::before {
    display: none;
  }
</style>
