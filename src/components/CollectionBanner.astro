---
---

<section class="collection-banner">
  <div class="container">
    <div class="collection-inner">
      <div class="collection-text">
        <span class="collection-tag">Current Collection</span>
        <h2 class="collection-title">Monsoon Series</h2>
        <p class="collection-desc">Inspired by Sri Lanka's monsoon season — rich, moody glazes that capture the beauty of rain-soaked earth and stormy skies. Each piece carries the raw energy of the season.</p>
        <a href="/shop" class="btn btn-primary">Explore Collection</a>
      </div>
      <div class="collection-photo">
        <img src="/images/abyee.jpg" alt="Monsoon Series collection piece" loading="lazy" decoding="async" width="400" height="500" />
      </div>
    </div>
  </div>
</section>

<style>
  .collection-banner {
    padding: var(--space-4xl) 0;
  }

  .collection-inner {
    background: linear-gradient(135deg, var(--color-terracotta), var(--color-terracotta-light));
    border-radius: var(--border-radius-xl);
    overflow: hidden;
    display: flex;
    align-items: center;
    padding: 0;
  }

  .collection-text {
    flex: 1;
    padding: var(--space-3xl) var(--space-3xl);
  }

  .collection-tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-extra);
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-md);
  }

  .collection-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    color: white;
    margin-bottom: var(--space-lg);
    line-height: 1.15;
  }

  .collection-desc {
    color: rgba(255, 255, 255, 0.85);
    max-width: 420px;
    margin-bottom: var(--space-2xl);
    line-height: 1.7;
  }

  .collection-text .btn-primary {
    background: white;
    color: var(--color-terracotta);
  }

  .collection-text .btn-primary:hover {
    background: var(--color-cream);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }

  .collection-photo {
    flex: 0 0 40%;
    display: flex;
    align-items: stretch;
  }

  .collection-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .collection-inner {
      flex-direction: column;
    }

    .collection-photo {
      display: none;
    }
  }
</style>
