---
import { Image } from 'astro:assets';
import collectionImg from '../assets/images/abyee.jpg';
---

<section class="collection-banner">
  <div class="collection-noise" aria-hidden="true"></div>
  <div class="container">
    <div class="collection-inner">
      <div class="collection-text">
        <span class="collection-tag">Current Collection</span>
        <h2 class="collection-title">Monsoon Series</h2>
        <p class="collection-desc">Inspired by Sri Lanka's monsoon season — rich, moody glazes that capture the beauty of rain-soaked earth and stormy skies. Each piece carries the raw energy of the season.</p>
        <a href="/shop" class="btn btn-primary collection-cta">Explore Collection</a>
      </div>
      <div class="collection-photo">
        <Image
          src={collectionImg}
          alt="Monsoon Series collection piece"
          width={400}
          height={500}
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .collection-banner {
    padding: var(--space-5xl) 0;
    background: var(--color-espresso);
    position: relative;
    overflow: hidden;
  }

  .collection-noise {
    position: absolute;
    inset: 0;
    background-image: var(--noise-texture);
    background-repeat: repeat;
    pointer-events: none;
    z-index: 1;
  }

  .collection-banner .container {
    position: relative;
    z-index: 2;
  }

  .collection-inner {
    display: flex;
    align-items: center;
    gap: var(--space-3xl);
  }

  .collection-text {
    flex: 1;
    padding: 0;
  }

  .collection-tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-extra);
    color: var(--color-terracotta-light);
    margin-bottom: var(--space-md);
  }

  .collection-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-cream);
    margin-bottom: var(--space-lg);
    line-height: 1.15;
  }

  .collection-desc {
    color: var(--color-beige);
    max-width: 420px;
    margin-bottom: var(--space-2xl);
    line-height: 1.7;
  }

  .collection-cta {
    background: var(--color-terracotta);
    color: var(--color-white);
  }

  .collection-cta:hover {
    background: var(--color-terracotta-dark);
    box-shadow: 0 8px 25px rgba(193, 119, 71, 0.3);
  }

  .collection-photo {
    flex: 0 0 40%;
    display: flex;
    align-items: stretch;
  }

  .collection-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--border-radius-img);
    box-shadow: var(--shadow-card);
  }

  @media (max-width: 768px) {
    .collection-inner {
      flex-direction: column;
    }

    .collection-photo {
      display: none;
    }
  }
</style>
