---
import { Image } from 'astro:assets';
import heroImg from '../assets/images/399x650-01.png';
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-circle" aria-hidden="true"></div>
  <div class="hero-content">
    <div class="hero-text">
      <span class="hero-tag">Handmade in Sri Lanka</span>
      <h1 class="hero-title">
        Clay, Fire &amp;<br /><em>Bold Expression</em>
      </h1>
      <div class="hero-actions">
        <a href="/shop" class="btn btn-primary">Browse Pieces</a>
        <a href="#process" class="btn btn-ghost hero-ghost">Our Story</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-image-main">
        <Image
          src={heroImg}
          alt="Handcrafted ceramic leaf plates"
          class="hero-img"
          width={399}
          height={650}
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-cream);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 120px;
    position: relative;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-circle {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(193, 119, 71, 0.08), transparent 70%);
    right: -200px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .hero-content {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-tag {
    color: var(--color-terracotta);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-extra);
    margin-bottom: var(--space-lg);
    display: inline-block;
  }

  .hero-title {
    color: var(--color-espresso);
    font-family: var(--font-serif);
    font-size: clamp(3rem, 6.5vw, 5rem);
    line-height: 1.05;
    margin-bottom: var(--space-2xl);
  }

  .hero-title em {
    font-family: var(--font-elegant);
    font-style: italic;
    color: var(--color-terracotta);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero-ghost {
    color: var(--color-charcoal);
    border-color: var(--color-beige-dark);
  }

  .hero-ghost:hover {
    border-color: var(--color-espresso);
    color: var(--color-espresso);
  }

  .hero-image-main {
    position: relative;
  }

  .hero-img {
    width: 100%;
    max-width: 399px;
    height: auto;
    border-radius: var(--border-radius-img);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
  }

  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      text-align: center;
    }

    .hero-img {
      margin: 0 auto;
      max-width: 300px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 100px;
      min-height: auto;
      padding-bottom: 4rem;
    }

    .hero-title {
      font-size: clamp(2.2rem, 6vw, 3rem);
    }

    .hero-tag {
      letter-spacing: 0.08em;
      font-size: 0.65rem;
    }
  }
</style>
