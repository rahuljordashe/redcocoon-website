---
import { Image } from 'astro:assets';
import makerPhoto from '../assets/images/abyee.jpg';
---

<section class="about-maker">
  <div class="container">
    <div class="about-maker-content">
      <div class="about-maker-image">
        <Image src={makerPhoto} alt="The maker at work in the Redcocoon studio" width={400} height={500} loading="lazy" />
      </div>
      <div class="about-maker-text">
        <span class="about-maker-tag">About the Maker</span>
        <h2 class="about-maker-title">Born from Clay <em>& Fire</em></h2>
        <p class="about-maker-body">
          Every piece at Redcocoon begins with a lump of clay and a quiet morning in our Colombo studio. I work slowly and intentionally — wheel-throwing each form by hand, layering glazes that respond to the kiln's unpredictable fire. The result is pottery that feels alive: no two pieces are ever quite the same.
        </p>
        <p class="about-maker-note">
          <em>Real maker portrait and personal story coming soon.</em>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .about-maker {
    background: var(--color-espresso);
    color: var(--color-cream);
    padding: var(--space-5xl) 0;
  }

  .about-maker-content {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .about-maker-image {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
  }

  .about-maker-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .about-maker-tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-extra);
    color: var(--color-terracotta);
    margin-bottom: var(--space-md);
  }

  .about-maker-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 400;
    margin-bottom: var(--space-lg);
    color: var(--color-cream);
  }

  .about-maker-title em {
    font-family: var(--font-elegant);
    font-style: italic;
    color: var(--color-terracotta);
  }

  .about-maker-body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgba(245, 240, 232, 0.85);
    max-width: 500px;
  }

  .about-maker-note {
    font-size: var(--text-sm);
    color: var(--color-clay);
    margin-top: var(--space-lg);
  }

  @media (max-width: 768px) {
    .about-maker-content {
      grid-template-columns: 1fr;
    }

    .about-maker-image {
      order: -1;
    }
  }
</style>
