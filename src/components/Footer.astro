---
import { getWhatsAppLink } from '../utils/whatsapp';
import { getInstagramDMLink, getInstagramProfileLink } from '../utils/instagram';
---

<footer class="footer" id="contact">
  <div class="footer-cta-banner">
    <div class="container">
      <h3 class="footer-cta-title">Ready to reserve a piece?</h3>
      <div class="footer-cta-buttons">
        <a href={getInstagramDMLink()} target="_blank" rel="noopener noreferrer" class="btn btn-instagram">Instagram DM</a>
        <a href={getWhatsAppLink("Hi! I'd like to reserve a piece.")} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp">WhatsApp</a>
        <a href="#contact-form" class="btn btn-ghost">Reservation Form</a>
      </div>
    </div>
  </div>
  <div class="footer-texture" aria-hidden="true"></div>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/logo.svg" alt="Redcocoon Pottery" class="footer-logo" width="50" height="50" loading="lazy" decoding="async">
        <p>Handcrafted ceramics made with love in our sunlit studio. Every piece tells a story of earth, fire, and human touch.</p>
        <div class="footer-social">
          <a href={getInstagramProfileLink()} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href={getWhatsAppLink("Hi! I'd like to know more about Redcocoon.")} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </a>
          <a href="mailto:hello@redcocoon.com" aria-label="Email">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-nav">
        <h4>Browse</h4>
        <ul>
          <li><a href="/#shop">All Pieces</a></li>
          <li><a href="/#collections">Collections</a></li>
          <li><a href="/#hospitality">Hospitality</a></li>
        </ul>
      </div>

      <div class="footer-nav">
        <h4>Connect</h4>
        <ul>
          <li><a href={getInstagramProfileLink()} target="_blank" rel="noopener noreferrer"><span class="footer-bullet footer-bullet-ig" aria-hidden="true"></span>Instagram</a></li>
          <li><a href={getWhatsAppLink("Hi!")} target="_blank" rel="noopener noreferrer"><span class="footer-bullet footer-bullet-wa" aria-hidden="true"></span>WhatsApp</a></li>
          <li><a href="mailto:hello@redcocoon.com"><span class="footer-bullet footer-bullet-email" aria-hidden="true"></span>Email</a></li>
        </ul>
      </div>

      <div class="footer-nav footer-subscribe">
        <h4>Stay Updated</h4>
        <form class="footer-form" onsubmit="return false;">
          <input type="email" placeholder="Your email" aria-label="Email for newsletter" class="footer-email-input">
          <button type="submit" class="footer-subscribe-btn">Subscribe</button>
        </form>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2026 Redcocoon Pottery. All rights reserved.</p>
      <div class="footer-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-espresso);
    position: relative;
    overflow: hidden;
  }

  .footer-cta-banner {
    background: var(--color-charcoal);
    padding: var(--space-3xl) 0;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .footer-cta-title {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: var(--color-cream);
    margin-bottom: var(--space-xl);
  }

  .footer-cta-buttons {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .footer-texture {
    position: absolute;
    inset: 0;
    background-image: var(--noise-texture);
    pointer-events: none;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 0.8fr 0.8fr;
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
    padding-top: var(--space-4xl);
    position: relative;
  }

  .footer-logo {
    height: 50px;
    margin-bottom: var(--space-lg);
    filter: brightness(0) invert(0.85);
  }

  .footer-brand p {
    font-size: 0.92rem;
    color: var(--color-sand);
    line-height: 1.7;
    max-width: 300px;
    margin-bottom: var(--space-lg);
  }

  .footer-social {
    display: flex;
    gap: var(--space-md);
  }

  .footer-social a {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-earth);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-sand);
    transition: all var(--transition-fast);
  }

  .footer-social a:hover {
    background: var(--color-terracotta);
    border-color: var(--color-terracotta);
    color: var(--color-white);
  }

  .footer-nav h4 {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-beige);
    margin-bottom: var(--space-lg);
  }

  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-nav a {
    font-size: var(--text-sm);
    color: var(--color-sand);
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer-nav a:hover {
    color: var(--color-terracotta-light);
    transform: translateX(3px);
  }

  .footer-bullet {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .footer-bullet-ig {
    background: var(--gradient-instagram);
  }

  .footer-bullet-wa {
    background: var(--color-whatsapp);
  }

  .footer-bullet-email {
    background: var(--color-terracotta);
  }

  .footer-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-email-input {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--color-earth);
    border-radius: var(--border-radius);
    padding: 0.7rem 1rem;
    color: var(--color-beige);
    font-size: var(--text-sm);
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .footer-email-input::placeholder {
    color: var(--color-clay);
  }

  .footer-email-input:focus {
    border-color: var(--color-terracotta);
  }

  .footer-subscribe-btn {
    background: var(--color-terracotta);
    color: var(--color-white);
    border: none;
    border-radius: var(--border-radius);
    padding: 0.7rem 1rem;
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .footer-subscribe-btn:hover {
    background: var(--color-terracotta-dark);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-top: 1px solid rgba(107, 91, 78, 0.3);
    position: relative;
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: var(--color-earth);
  }

  .footer-links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer-links a {
    font-size: var(--text-xs);
    color: var(--color-earth);
  }

  .footer-links a:hover {
    color: var(--color-beige);
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }
  }
</style>
